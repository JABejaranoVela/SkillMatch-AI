# Copy this file to .env.prod and replace every placeholder before deploying.
# Do not commit .env.prod.

ENVIRONMENT=production

POSTGRES_DB=skillmatch
POSTGRES_USER=skillmatch
POSTGRES_PASSWORD=REPLACE_WITH_POSTGRES_PASSWORD
DATABASE_URL=postgresql+psycopg://skillmatch:REPLACE_WITH_POSTGRES_PASSWORD@db:5432/skillmatch

SECRET_KEY=REPLACE_WITH_STRONG_SECRET_KEY
BACKEND_CORS_ORIGINS=["https://REPLACE_WITH_FRONTEND_DOMAIN"]
TRUST_PROXY_HEADERS=false

SESSION_DAYS=30
SESSION_COOKIE_NAME=skillmatch_session
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
FRONTEND_URL=https://REPLACE_WITH_FRONTEND_DOMAIN

EMAIL_PROVIDER=brevo
EMAIL_FROM=SkillMatch AI <noreply@REPLACE_WITH_VERIFIED_DOMAIN>
BREVO_API_KEY=REPLACE_WITH_BREVO_API_KEY
BREVO_API_URL=https://api.brevo.com/v3/smtp/email
EMAIL_PAYLOAD_ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY
EMAIL_WORKER_POLL_SECONDS=2
EMAIL_WORKER_BATCH_SIZE=10
EMAIL_WORKER_STALE_MINUTES=15
EMAIL_MAX_ATTEMPTS=6
EMAIL_HTTP_TIMEOUT_SECONDS=15

PASSWORD_RESET_TTL_MINUTES=60
PASSWORD_RESET_MAX_REQUESTS_PER_HOUR=5
LOGIN_RATE_LIMIT_ATTEMPTS=10
LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
REGISTER_RATE_LIMIT_PER_HOUR=5
RESEND_RATE_LIMIT_PER_HOUR=5
FORGOT_PASSWORD_IP_RATE_LIMIT_PER_HOUR=20
RESET_PASSWORD_RATE_LIMIT_PER_HOUR=10
CHANGE_PASSWORD_RATE_LIMIT_PER_HOUR=5
PUBLIC_DEMO_RATE_LIMIT_PER_HOUR=5
JOB_SEARCH_RATE_LIMIT_PER_HOUR=6
JOB_SEARCH_STALE_MINUTES=30

CLEANUP_SESSION_RETENTION_DAYS=30
CLEANUP_TOKEN_RETENTION_DAYS=7
CLEANUP_OUTBOX_RETENTION_DAYS=30

UPLOAD_DIR=storage/resumes
SKILLS_DICTIONARY_PATH=data/skills/skills.es.json
MAX_UPLOAD_SIZE_MB=10
RESUME_MAX_PAGES=25
RESUME_MIN_TEXT_CHARS=50
PUBLIC_DEMO_MAX_PAGES=25
PUBLIC_DEMO_MIN_TEXT_CHARS=50
PUBLIC_DEMO_SKILLS_LIMIT=12

EMBEDDINGS_ENABLED=true
EMBEDDINGS_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
SKILL_NER_ENABLED=false
SKILL_NER_MODEL_NAME=urchade/gliner_medium-v2.1

TECNOEMPLEO_BASE_URL=https://www.tecnoempleo.com
INFOJOBS_API_URL=https://api.infojobs.net/api/1/offer
INFOJOBS_CLIENT_ID=
INFOJOBS_CLIENT_SECRET=
PROFILE_JOB_IMPORT_LIMIT=12
RECOMMENDATIONS_LIMIT=50
